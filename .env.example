# =============================================================================
# Le CFO Masqué - Test de positionnement Excel
# Variables d'environnement (à copier dans .env.local pour le développement local)
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# URL publique du projet Supabase (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co

# Clé anonyme publique Supabase (Settings > API > Project API keys > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clé service_role Supabase (Settings > API > Project API keys > service_role)
# !!! NE JAMAIS exposer côté client. Utilisée uniquement par les routes API admin.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# URL canonique de l'application (utilisée pour les liens dans les courriels,
# le PDF et l'OG share). En prod, ex: https://test.lecfomasque.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL de la politique de confidentialité affichée sur l'écran de consentement.
# Placeholder pour Phase 1 — remplacer par la vraie URL une fois fournie.
NEXT_PUBLIC_PRIVACY_POLICY_URL=https://www.lecfomasque.com/#politique-a-venir

# URL des conditions générales (optionnel, peut être laissé vide)
NEXT_PUBLIC_TERMS_URL=https://www.lecfomasque.com/#conditions-a-venir

# -----------------------------------------------------------------------------
# IA (Phase 2 — non utilisé en Phase 1)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
