import { NextResponse, type NextRequest } from "next/server";
import { createServerClient, type CookieOptions } from "@supabase/ssr";
import type { Database } from "@/lib/supabase/types";

/**
 * Middleware : maintient la session Supabase a jour et protege /admin.
 */
export async function middleware(request: NextRequest) {
  // Propage le pathname dans un header pour que les layouts serveur puissent
  // connaître l'URL courante (sinon non accessible nativement en App Router).
  // Indispensable pour qu'admin/layout.tsx sache s'il est sur /admin/login et
  // évite la boucle infinie d'auth check (ERR_TOO_MANY_REDIRECTS).
  const headersAvecPath = new Headers(request.headers);
  headersAvecPath.set("x-pathname", request.nextUrl.pathname);
  let response = NextResponse.next({ request: { headers: headersAvecPath } });

  const supabase = createServerClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
    {
      cookies: {
        getAll() {
          return request.cookies.getAll();
        },
        setAll(cookiesToSet: Array<{ name: string; value: string; options: CookieOptions }>) {
          cookiesToSet.forEach(({ name, value }) =>
            request.cookies.set(name, value)
          );
          response = NextResponse.next({ request: { headers: headersAvecPath } });
          cookiesToSet.forEach(({ name, value, options }) =>
            response.cookies.set(name, value, options)
          );
        }
      }
    }
  );

  const { data: { user } } = await supabase.auth.getUser();


  const { pathname } = request.nextUrl;
  const protege = pathname.startsWith("/admin") && !pathname.startsWith("/admin/login");

  if (protege && !user) {
    const url = request.nextUrl.clone();
    url.pathname = "/admin/login";
    url.searchParams.set("redirect", pathname);
    return NextResponse.redirect(url);
  }

  if (pathname.startsWith("/admin/login") && user) {
    const url = request.nextUrl.clone();
    url.pathname = "/admin";
    return NextResponse.redirect(url);
  }

  return response;
}

export const config = {
  matcher: ["/admin/:path*"]
};
